# Isi dengan nomor WhatsApp toko dalam format internasional, tanpa tanda + atau spasi.
VITE_WHATSAPP_NUMBER=6281234567890

# Base URL API untuk build Android/Capacitor.
# Emulator Android memakai 10.0.2.2 untuk mengakses port 3001 di komputer.
# Pada perangkat fisik, ganti dengan IP LAN komputer, misalnya http://192.168.1.10:3001.
VITE_API_BASE_URL=http://10.0.2.2:3001

# Database lokal untuk npm run dev.
# Jalankan PostgreSQL di komputer ini, lalu sesuaikan user/password/database jika berbeda.
DATABASE_URL=postgres://postgres@127.0.0.1:5432/postgres
# Contoh jika PostgreSQL memakai password:
# DATABASE_URL=postgres://postgres:password_anda@127.0.0.1:5432/postgres

# Konfigurasi aplikasi. Ganti semua nilai sebelum website dipublikasikan.
APP_ADMIN_PASSWORD=ganti-password-aman
APP_ADMIN_EMAIL=admin@franchise.local
APP_JWT_SECRET=ganti-dengan-kode-rahasia-yang-panjang
APP_CASHIER_EMAIL=cashier@franchise.local
APP_CASHIER_PASSWORD=ganti-password-cashier
APP_MANAGER_EMAIL=manager@franchise.local
APP_MANAGER_PASSWORD=ganti-password-manager

# Pembayaran online Midtrans Snap. Kosongkan MIDTRANS_SERVER_KEY untuk memakai simulator lokal.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
PUBLIC_APP_URL=http://localhost:5175

# Origin tambahan yang boleh mengakses API. Pisahkan dengan koma jika lebih dari satu.
MOBILE_ALLOWED_ORIGINS=capacitor://localhost,https://localhost
