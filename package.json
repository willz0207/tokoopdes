{
  "name": "franchise-ordering-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c red,cyan \"tsx watch server/start.ts\" \"vite --host 0.0.0.0\"",
    "dev:api": "tsx watch server/start.ts",
    "dev:web": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/start.ts",
    "build": "tsc -b && vite build && tsc -p server/tsconfig.json",
    "mobile:build": "npm run build && cap sync android",
    "mobile:open": "cap open android",
    "mobile:run": "npm run mobile:build && cap run android",
    "mobile:apk": "npm run mobile:build && cd android && gradlew.bat assembleDebug",
    "start": "node server-dist/start.js",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report outputs/playwright-report"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@netlify/functions": "^5.3.0",
    "@vitejs/plugin-react": "latest",
    "dotenv": "latest",
    "express": "latest",
    "helmet": "latest",
    "jsonwebtoken": "latest",
    "lucide-react": "latest",
    "pg": "^8.22.0",
    "react": "latest",
    "react-dom": "latest",
    "serverless-http": "^4.0.0",
    "vite": "latest"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "latest"
  }
}
